    "express": "^5.2.1",
    "lucide-react": "^1.11.0",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
